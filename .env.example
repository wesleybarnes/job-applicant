# ─── Required ──────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ──────────────────────────────────────────────────────────────
# JSearch API key for real job search (RapidAPI)
# Without this, demo jobs are shown instead
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/JSearch
JSEARCH_API_KEY=

# App settings
DEBUG=false
FRONTEND_URL=http://localhost:5173
DATABASE_URL=sqlite:///./data/job_applicant.db
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
