# ─── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Auth (Clerk) ──────────────────────────────────────────────────────────
# Get at https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Your email — gets unlimited free usage (admin bypass)
ADMIN_EMAIL=you@gmail.com

# Secret used to encrypt saved site passwords at rest (any random string).
# Leave blank to disable saving passwords (the hunt then caches cookies only).
CREDENTIALS_SECRET_KEY=

# ─── Closed-beta + feedback digest ─────────────────────────────────────────
# Set INVITE_ONLY=false to open signups. Daily feedback digest email is sent
# to ADMIN_EMAIL by default (override with FEEDBACK_DIGEST_TO). Easiest SMTP
# setup: Gmail + a 16-char "App Password" — https://myaccount.google.com/apppasswords
INVITE_ONLY=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=
SMTP_FROM=Envia Feedback <you@gmail.com>
FEEDBACK_DIGEST_TO=
FEEDBACK_DIGEST_HOUR_UTC=14

# ─── Payments (Stripe) ─────────────────────────────────────────────────────
# Get at https://dashboard.stripe.com — leave blank to disable payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Career knowledge base (RAG) ───────────────────────────────────────────
# Embeddings power semantic retrieval of the most relevant resume/experience
# chunks per job. Get a key at https://dashboard.voyageai.com
# Leave VOYAGE_API_KEY blank to disable RAG (agent falls back to resume text).
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3.5
RAG_TOP_K=6

# ─── Optional ──────────────────────────────────────────────────────────────
JSEARCH_API_KEY=
DEBUG=false
FRONTEND_URL=http://localhost:5173
DATABASE_URL=sqlite:///./data/job_applicant.db
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
